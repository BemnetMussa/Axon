# Copy to a real env file (gitignored):
#   cp .env.example .env
#
# === Database (pick ONE style) ===
#
# Local Docker Compose maps Postgres to host port 5433 (see compose.yaml):
DATABASE_URL=postgresql://axon:axon123@127.0.0.1:5433/axon_db
#
# Or native Postgres on default port:
# DATABASE_URL=postgresql://axon:axon123@127.0.0.1:5432/axon_db
#
# Or Supabase / pooler — set DB_* (takes priority over DATABASE_URL; ssl required):
# DB_USER=postgres.your_project_ref
# DB_PASSWORD=your_password
# DB_HOST=aws-0-us-east-1.pooler.supabase.com
# DB_PORT=5432
# DB_NAME=postgres

# === Required ===
# Groq: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Shared with SvelteKit proxy — must match fronted AXON_INTERNAL_SECRET
# Generate: openssl rand -base64 32
AXON_INTERNAL_SECRET=replace-with-shared-secret-matching-frontend

# === Optional ===
# GitHub API (higher rate limits): https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_AUTH_STYLE=token

INGEST_INTERVAL_HOURS=4
DB_ECHO=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
