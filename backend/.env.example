# === Database ===
# Option A: Supabase / remote PostgreSQL (recommended for deployment)
DB_USER=postgres.your_project_ref
DB_PASSWORD=your_password
DB_HOST=aws-0-us-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres

# Option B: Local PostgreSQL (Docker or native)
# Just set DATABASE_URL — the DB_* vars above take priority if set
# DATABASE_URL=postgresql://axon:axon123@127.0.0.1:5432/axon_db

# === Required ===
# Groq API key for AI insights, briefs, and chat
# Get one free at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# === Optional ===
# GitHub personal access token (avoids rate limits)
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here
# Use "bearer" for fine-grained PATs, "token" for classic PATs (default)
# GITHUB_AUTH_STYLE=token

# Background ingestion interval (default: 4 hours)
INGEST_INTERVAL_HOURS=4

# Set to "true" to log SQL queries
DB_ECHO=false
