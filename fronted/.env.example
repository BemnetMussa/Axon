# Same Postgres URL as the FastAPI backend (Better Auth tables + Axon data).
DATABASE_URL=postgresql://axon:axon123@127.0.0.1:5432/axon_db

# Required: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-strong-random-secret
# Optional: canonical public URL (fallback for OAuth if host detection fails). Dynamic base URL uses request host + allowedHosts.
BETTER_AUTH_URL=http://localhost:5173
# Optional: extra hosts for Better Auth (comma-separated), e.g. mydomain.com — *.vercel.app is already allowed
# BETTER_AUTH_ALLOWED_HOSTS=

# Google OAuth (OAuth consent + credentials in Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Required: must match backend AXON_INTERNAL_SECRET — used by /api/backend proxy to FastAPI
AXON_INTERNAL_SECRET=replace-with-shared-secret-matching-backend

# Required: where the Python API listens (server-side only; browser calls /api/backend)
INTERNAL_API_URL=http://127.0.0.1:8080

# Optional: production site URL for trustedOrigins
# PUBLIC_APP_URL=https://your-app.vercel.app
