# Same Postgres URL as the FastAPI backend (Better Auth tables + Axon data).
DATABASE_URL=postgresql://axon:axon123@127.0.0.1:5432/axon_db

# openssl rand -base64 32
BETTER_AUTH_SECRET=your-32-char-min-secret-here-change-me
# Public URL of this SvelteKit app (OAuth redirects, trusted origin). No trailing slash.
# On Vercel you can omit this if VERCEL_URL is set — or set explicitly, e.g. https://axon-phi-ruby.vercel.app
BETTER_AUTH_URL=http://localhost:5173

# Google OAuth (OAuth consent + credentials in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match backend AXON_INTERNAL_SECRET — used by /api/backend proxy to FastAPI
AXON_INTERNAL_SECRET=generate-a-long-random-string-and-match-backend

# Where the Python API listens (server-side only; browser calls /api/backend)
INTERNAL_API_URL=http://127.0.0.1:8000

# Optional: production site URL for trustedOrigins
# PUBLIC_APP_URL=https://your-app.vercel.app
