# Copy to a real env file (gitignored):
#   cp .env.example .env
#
# Same Postgres as FastAPI (Better Auth tables live here too).

# Docker Compose (backend compose.yaml): host port 5433
DATABASE_URL=postgresql://axon:axon123@127.0.0.1:5433/axon_db
#
# Native local Postgres:
# DATABASE_URL=postgresql://axon:axon123@127.0.0.1:5432/axon_db

# Required — generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-strong-random-secret

BETTER_AUTH_URL=http://localhost:5173
# BETTER_AUTH_ALLOWED_HOSTS=yourdomain.com,other.dev

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Must match backend AXON_INTERNAL_SECRET (SvelteKit -> FastAPI proxy)
AXON_INTERNAL_SECRET=replace-with-shared-secret-matching-backend

# FastAPI base URL (server-side only; browser uses /api/backend)
INTERNAL_API_URL=http://127.0.0.1:8000

# Optional — production / extra trusted origins
# PUBLIC_APP_URL=https://your-app.vercel.app
